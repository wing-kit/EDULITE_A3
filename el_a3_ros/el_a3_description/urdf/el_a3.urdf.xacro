<?xml version="1.0" ?>
<!-- EL-A3 6-DOF Robot Arm URDF with ros2_control support -->
<!-- Updated from EDULITE-A3 model -->
<robot name="EL-A3" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Arguments -->
  <xacro:arg name="use_mock_hardware" default="false"/>
  <xacro:arg name="use_gazebo" default="false"/>
  <xacro:arg name="gazebo_ros2_control_params" default=""/>
  <xacro:arg name="mesh_prefix" default="package://el_a3_description/meshes/"/>
  <xacro:arg name="can_interface" default="can0"/>
  <xacro:arg name="host_can_id" default="253"/>
  <xacro:arg name="wrist_motor_type" default="EL05"/>

  <!-- Wrist motor parameters (EL05: 6Nm, RS05: 5.5Nm) -->
  <xacro:property name="wrist_motor_type" value="$(arg wrist_motor_type)"/>
  <xacro:property name="wrist_effort" value="${5.5 if wrist_motor_type == 'RS05' else 6.0}"/>
  <xacro:property name="mesh_prefix" value="$(arg mesh_prefix)"/>
  
  <!-- Include ros2_control -->
  <xacro:include filename="$(find el_a3_description)/urdf/el_a3_ros2_control.xacro"/>

  <!-- Materials -->
  <material name="orange">
    <color rgba="0.972549 0.529412 0.00392157 1"/>
  </material>
  <material name="dark_brown">
    <color rgba="0.301961 0.290196 0.262745 1"/>
  </material>

  <!-- Base link (world) -->
  <link name="base_link"/>

  <joint name="base_to_l1" type="fixed">
    <parent link="base_link"/>
    <child link="l1_urdf_urdf_asm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Link l1_urdf_urdf_asm (Base) -->
  <link name="l1_urdf_urdf_asm">
    <inertial>
      <origin xyz="4.66057e-08 7.85527e-05 0.0336468" rpy="0 0 0"/>
      <mass value="0.498832"/>
      <inertia ixx="0.000371872" ixy="-1.33362e-08" ixz="5.96807e-10"
               iyy="0.000365137" iyz="-1.36721e-06" izz="0.000388475"/>
    </inertial>
    <visual>
      <origin xyz="-0.000643355 0 0.059" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l1.stl"/>
      </geometry>
      <material name="dark_brown"/>
    </visual>
    <collision>
      <origin xyz="-0.000643355 0 0.059" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l1.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Link l1_link_urdf_asm -->
  <link name="l1_link_urdf_asm">
    <inertial>
      <origin xyz="-0.00232762 -0.00161986 0.0421389" rpy="0 0 0"/>
      <mass value="0.105244"/>
      <inertia ixx="0.000163151" ixy="-3.25924e-06" ixz="1.01303e-05"
               iyy="9.80821e-05" iyz="1.04567e-05" izz="0.000118753"/>
    </inertial>
    <visual>
      <origin xyz="-0.000642857 0 0.001" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l2.stl"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="-0.000642857 0 0.001" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l2.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Link l2_l3_urdf_asm -->
  <link name="l2_l3_urdf_asm">
    <inertial>
      <origin xyz="0.0949957 1.32911e-06 0.000626283" rpy="0 0 0"/>
      <mass value="0.836196"/>
      <inertia ixx="0.000419405" ixy="-4.27021e-07" ixz="-4.05336e-10"
               iyy="0.00708317" iyz="2.8291e-09" izz="0.00707892"/>
    </inertial>
    <visual>
      <origin xyz="0.009 -0.07 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l3.stl"/>
      </geometry>
      <material name="dark_brown"/>
    </visual>
    <collision>
      <origin xyz="0.009 -0.07 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l3.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Link l3_lnik_urdf_asm -->
  <link name="l3_lnik_urdf_asm">
    <inertial>
      <origin xyz="-0.0743466 -0.0535452 -0.00326782" rpy="0 0 0"/>
      <mass value="0.262025"/>
      <inertia ixx="0.000333463" ixy="-0.000182996" ixz="-9.89508e-06"
               iyy="0.00130159" iyz="1.18614e-05" izz="0.00133147"/>
    </inertial>
    <visual>
      <origin xyz="-0.181 -0.07 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l4.stl"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="-0.181 -0.07 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l4.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Link l4_l5_urdf_asm -->
  <link name="l4_l5_urdf_asm">
    <inertial>
      <origin xyz="-0.0242818 -0.0298393 0.000368105" rpy="0 0 0"/>
      <mass value="0.55715"/>
      <inertia ixx="0.0006785" ixy="-0.000401622" ixz="-5.0507e-06"
               iyy="0.000503952" iyz="-6.21816e-06" izz="0.000993465"/>
    </inertial>
    <visual>
      <origin xyz="0.004 0.134 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l5.stl"/>
      </geometry>
      <material name="dark_brown"/>
    </visual>
    <collision>
      <origin xyz="0.004 0.134 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l5.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Link part_9 -->
  <link name="part_9">
    <inertial>
      <origin xyz="0.00527533 0 -0.0216678" rpy="0 0 0"/>
      <mass value="0.0392349"/>
      <inertia ixx="1.45554e-05" ixy="0" ixz="4.08768e-06"
               iyy="1.4787e-05" iyz="0" izz="6.36147e-06"/>
    </inertial>
    <visual>
      <origin xyz="0.0532 0 0.173" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l6.stl"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0.0532 0 0.173" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}l6.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Link l5_l6_urdf_asm (End Effector) -->
  <link name="l5_l6_urdf_asm">
    <inertial>
      <origin xyz="8.14367e-06 8.87434e-05 0.0699256" rpy="0 0 0"/>
      <mass value="0.657292"/>
      <inertia ixx="0.00132624" ixy="1.41465e-05" ixz="9.49712e-08"
               iyy="0.00177268" iyz="-7.87717e-06" izz="0.000610685"/>
    </inertial>
    <!-- Part el05_l6 -->
    <visual>
      <origin xyz="0 0 -0.0755" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}el05_l6.stl"/>
      </geometry>
      <material name="dark_brown"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0755" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}el05_l6.stl"/>
      </geometry>
    </collision>
    <!-- Part jaw -->
    <visual>
      <origin xyz="0 0 -0.0755" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}jaw.stl"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0755" rpy="3.14159 0 0"/>
      <geometry>
        <mesh filename="${mesh_prefix}jaw.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- End Effector link -->
  <link name="end_effector"/>

  <!-- Joints -->
  <!-- Joint L1 (RS00 Motor 1) -->
  <joint name="L1_joint" type="revolute">
    <origin xyz="0 0 0.06" rpy="3.14159 0 0"/>
    <parent link="l1_urdf_urdf_asm"/>
    <child link="l1_link_urdf_asm"/>
    <axis xyz="0 0 -1"/>
    <limit effort="14" velocity="33" lower="-2.79253" upper="2.79253"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Joint L2 (RS00 Motor 2) -->
  <joint name="L2_joint" type="revolute">
    <origin xyz="-0.00964286 0 -0.069" rpy="-1.5708 0 0"/>
    <parent link="l1_link_urdf_asm"/>
    <child link="l2_l3_urdf_asm"/>
    <axis xyz="0 0 1"/>
    <limit effort="14" velocity="33" lower="0" upper="3.66519"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Joint L3 (RS00 Motor 3) -->
  <joint name="L3_joint" type="revolute">
    <origin xyz="0.19 0 0" rpy="0 0 0"/>
    <parent link="l2_l3_urdf_asm"/>
    <child link="l3_lnik_urdf_asm"/>
    <axis xyz="0 0 1"/>
    <limit effort="14" velocity="33" lower="-4.01426" upper="0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Joint L4 (${wrist_motor_type} Motor 4) -->
  <joint name="L4_joint" type="revolute">
    <origin xyz="-0.185 0.064 0" rpy="-3.14159 0 0"/>
    <parent link="l3_lnik_urdf_asm"/>
    <child link="l4_l5_urdf_asm"/>
    <axis xyz="0 0 -1"/>
    <limit effort="${wrist_effort}" velocity="50" lower="-1.0472" upper="1.5708"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- Joint L5 (${wrist_motor_type} Motor 5) -->
  <joint name="L5_joint" type="revolute">
    <origin xyz="-0.0492 -0.038 0" rpy="-1.5708 0 0"/>
    <parent link="l4_l5_urdf_asm"/>
    <child link="part_9"/>
    <axis xyz="0 0 1"/>
    <limit effort="${wrist_effort}" velocity="50" lower="-1.5708" upper="1.5708"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- Joint L6 (${wrist_motor_type} Motor 6) -->
  <joint name="L6_joint" type="revolute">
    <origin xyz="0.00685 0 0.039" rpy="-1.5708 0 -1.5708"/>
    <parent link="part_9"/>
    <child link="l5_l6_urdf_asm"/>
    <axis xyz="0 0 1"/>
    <limit effort="${wrist_effort}" velocity="50" lower="-1.5708" upper="1.5708"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- End Effector joint (fixed to last arm link, defines TCP for MoveIt planning) -->
  <joint name="end_effector_joint" type="fixed">
    <origin xyz="0 0 -0.074" rpy="0 0 0"/>
    <parent link="l5_l6_urdf_asm"/>
    <child link="end_effector"/>
  </joint>

  <!-- Joint L7 (${wrist_motor_type} Motor 7 - Gripper, separate kinematic branch) -->
  <joint name="L7_joint" type="revolute">
    <origin xyz="0 0 -0.074" rpy="0 0 0"/>
    <parent link="l5_l6_urdf_asm"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="${wrist_effort}" velocity="50" lower="-1.5708" upper="1.5708"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <link name="gripper_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ros2_control interface -->
  <xacro:el_a3_ros2_control 
    use_mock_hardware="$(arg use_mock_hardware)"
    use_gazebo="$(arg use_gazebo)"
    can_interface="$(arg can_interface)"
    host_can_id="$(arg host_can_id)"
    wrist_motor_type="$(arg wrist_motor_type)"/>

  <xacro:if value="$(arg use_gazebo)">
    <gazebo>
      <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
        <parameters>$(arg gazebo_ros2_control_params)</parameters>
      </plugin>
    </gazebo>
  </xacro:if>

</robot>
